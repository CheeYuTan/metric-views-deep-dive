flowchart LR
  subgraph RawFacts[Raw finance facts]
    GL[fact_gl_transactions<br/>journal-line grain]
    TGT[fact_monthly_targets<br/>monthly target grain]
    BAL[fact_month_end_balances<br/>month-end balance grain]
  end

  subgraph SharedDims[Shared business dimensions]
    ACC[dim_account<br/>account hierarchy]
    PROD[dim_product<br/>product hierarchy]
    ENT[dim_entity<br/>entity hierarchy]
    SEG[dim_customer_segment<br/>segment hierarchy]
    CAL[dim_calendar<br/>fiscal hierarchy]
  end

  BASE[finance_semantic_base<br/>common semantic source]
  MV[finance_metric_view<br/>governed Metric View]

  GL --> BASE
  TGT --> BASE
  BAL --> BASE
  ACC --> BASE
  PROD --> BASE
  ENT --> BASE
  SEG --> BASE
  CAL --> BASE
  BASE --> MV

  MV --> LOD[LOD measures<br/>fixed and coarser]
  MV --> WIN[Window measures<br/>YTD, R12, prior year]
  MV --> BALM[Semiadditive balance<br/>last over time]
